$conn = null;
try {
    $conn = db::connect("sqlite://:memory:");
    log::info("connect OK");
    db::exec($conn, "CREATE TABLE test (id INTEGER PRIMARY KEY, val TEXT)", []);
    log::info("exec OK");
} catch ($e) {
    log::error("hata: " . $e);
}

route("GET", "/ping", function() use ($conn) {
    print(json::encode(["ok" => true]));
});
route("404", function() { response::status(404); print(json::encode(["ok" => false])); });
