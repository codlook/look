FROM almalinux:8

# Sistemd + gerekli paketler
RUN dnf install -y \
    httpd php php-cli php-json php-mbstring \
    sudo curl bash procps-ng \
    --setopt=install_weak_deps=False && \
    dnf clean all

# Prefork MPM — mod_php ile uyumlu
RUN sed -i 's/^LoadModule mpm_event_module/#LoadModule mpm_event_module/' /etc/httpd/conf.modules.d/00-mpm.conf && \
    sed -i 's/^#LoadModule mpm_prefork_module/LoadModule mpm_prefork_module/' /etc/httpd/conf.modules.d/00-mpm.conf

# Plesk dizin yapısını simüle et
RUN mkdir -p \
    /usr/local/psa/admin/htdocs/modules/look-lang \
    /usr/local/psa/admin/htdocs/modules/catalog/icons/32 \
    /usr/local/psa/admin/htdocs/modules/catalog/icons/64 \
    /usr/local/psa/admin/htdocs/modules/catalog/icons/128 \
    /var/www/vhosts/tobiyo.com/look.tobiyo.com/httpdocs \
    /var/www/vhosts/look.tobiyo.com/conf \
    /var/www/vhosts/system/look.tobiyo.com/conf \
    /var/log/look \
    /opt/look

# psaadm kullanicisi (Plesk PHP process user)
RUN useradd -r -s /sbin/nologin psaadm 2>/dev/null || true

# Apache: Plesk admin panel simülasyonu (port 8880)
RUN mkdir -p /etc/httpd/conf.d
COPY docker/plesk-mock.conf /etc/httpd/conf.d/plesk-mock.conf

# Eklenti dosyalarını kopyala (htdocs/)
COPY htdocs/ /usr/local/psa/admin/htdocs/modules/look-lang/
COPY htdocs/scripts/ /usr/local/psa/admin/htdocs/modules/look-lang/scripts/

# Script izinleri
RUN chmod +x /usr/local/psa/admin/htdocs/modules/look-lang/scripts/*.sh

# install.sh çalıştır (Plesk kurulum adımını simüle et)
RUN bash /usr/local/psa/admin/htdocs/modules/look-lang/scripts/install.sh 2>&1 | tee /tmp/install.log

# Apache PHP kullanıcısını psaadm yap (Plesk gibi)
RUN echo 'User psaadm' >> /etc/httpd/conf/httpd.conf && \
    echo 'Group psaadm' >> /etc/httpd/conf/httpd.conf || true

# plesk komutunu simüle et
COPY docker/plesk-mock.sh /usr/bin/plesk
RUN chmod +x /usr/bin/plesk

# Başlangıç scripti
COPY docker/start.sh /start.sh
RUN chmod +x /start.sh

EXPOSE 8880

CMD ["/start.sh"]
