{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "LOOK",
  "scopeName": "source.look",
  "fileTypes": ["lk"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings-double" },
    { "include": "#strings-single" },
    { "include": "#strings-backtick" },
    { "include": "#keywords-control" },
    { "include": "#keywords-declaration" },
    { "include": "#keywords-operator" },
    { "include": "#modules-builtin" },
    { "include": "#modules-stdlib" },
    { "include": "#variables" },
    { "include": "#constants-language" },
    { "include": "#constants-numeric" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {

    "comments": {
      "name": "comment.line.number-sign.look",
      "match": "#.*$"
    },

    "strings-double": {
      "name": "string.quoted.double.look",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "meta.embedded.expression.look",
          "match": "\\{\\$[^}]+\\}",
          "captures": {
            "0": { "name": "variable.other.interpolated.look" }
          }
        },
        {
          "name": "constant.character.escape.look",
          "match": "\\\\[nrtv\\\\\"'$]"
        }
      ]
    },

    "strings-single": {
      "name": "string.quoted.single.look",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.look",
          "match": "\\\\[\\\\']"
        }
      ]
    },

    "strings-backtick": {
      "name": "string.quoted.other.backtick.look",
      "begin": "`",
      "end": "`"
    },

    "keywords-control": {
      "name": "keyword.control.look",
      "match": "\\b(if|elseif|else|while|for|foreach|as|break|continue|return|switch|case|default|try|catch|finally|parallel|in)\\b"
    },

    "keywords-declaration": {
      "name": "keyword.other.declaration.look",
      "match": "\\b(function|route|use|struct|const|iota|print|write)\\b"
    },

    "keywords-operator": {
      "name": "keyword.operator.logical.look",
      "match": "\\b(null|true|false|and|or|not)\\b"
    },

    "modules-builtin": {
      "patterns": [
        {
          "name": "support.function.builtin.look",
          "match": "\\b(db|ws|sse|timer|request|response|session|cookie|json|route|log|env|config|file|date|template|auth|validator|html|string|math|array|type|runtime|cache|queue|jobs|mail|http|crypto)(?=::)"
        },
        {
          "name": "support.function.method.look",
          "match": "::[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },

    "modules-stdlib": {
      "name": "support.function.call.look",
      "match": "\\b(count|push|pop|send|receive|close|chan_size|int|float|str|string|bool|isset|unset|type|len|range|keys|values|sort|reverse|unique|filter|map|reduce|slice|contains|json_encode|json_decode|channel)(?=\\s*\\()"
    },

    "variables": {
      "name": "variable.other.look",
      "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*"
    },

    "constants-language": {
      "name": "constant.language.look",
      "match": "\\b(null|true|false)\\b"
    },

    "constants-numeric": {
      "patterns": [
        {
          "name": "constant.numeric.float.look",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.look",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.look",
          "match": "(===|!==|<=>|==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.look",
          "match": "(\\+=|-=|\\*=|\\/=|\\.=|\\*\\*=|%=|&=|\\|=|\\^=|<<=|>>=|\\?\\?=|=)"
        },
        {
          "name": "keyword.operator.arithmetic.look",
          "match": "(\\*\\*|\\+\\+|--|\\*|\\/|%|\\+|-)"
        },
        {
          "name": "keyword.operator.logical.look",
          "match": "(&&|\\|\\||!|\\?\\?|\\?:)"
        },
        {
          "name": "keyword.operator.bitwise.look",
          "match": "(&|\\||\\^|~|<<|>>)"
        },
        {
          "name": "keyword.operator.string.look",
          "match": "(?<![a-zA-Z0-9_])\\.(?![a-zA-Z_])"
        },
        {
          "name": "keyword.operator.ternary.look",
          "match": "(\\?|:)"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.definition.block.look",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.array.look",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.separator.look",
          "match": "[,;]"
        },
        {
          "name": "punctuation.accessor.look",
          "match": "(?<=[a-zA-Z0-9_\\$])\\."
        }
      ]
    }
  }
}
