{
  "name": "look-lang",
  "displayName": "LOOK Language",
  "description": "Syntax highlighting, snippets, and language support for the LOOK programming language — developed by Codlook Bilişim (codlook.com)",
  "version": "1.2.0",
  "publisher": "codlook",
  "icon": "look-icon.png",
  "author": {
    "name": "Codlook Bilişim",
    "url": "https://codlook.com"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "look",
    "look-lang",
    "web runtime",
    "fastcgi",
    "codlook"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Codlook/look"
  },
  "homepage": "https://codlook.com",
  "bugs": {
    "url": "https://github.com/Codlook/look/issues"
  },
  "contributes": {
    "languages": [
      {
        "id": "look",
        "aliases": [
          "LOOK",
          "look"
        ],
        "extensions": [
          ".lk"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "look",
        "scopeName": "source.look",
        "path": "./syntaxes/look.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "look",
        "path": "./snippets/look.json"
      }
    ]
  },
  "main": "",
  "scripts": {
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.22.0"
  }
}
